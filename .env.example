# SanctionPay Environment Variables
# Copy this to .env and fill in your values

# Anthropic API (required for AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# CSPR.cloud API key (get from console.cspr.build)
CSPR_CLOUD_API_KEY=your-cspr-cloud-key

# Casper contract hash (after deploying with Odra)
CONTRACT_HASH=

# Casper account that has write access to contract
WRITER_SECRET_KEY=

# x402 Facilitator (default: CSPR.cloud hosted)
X402_FACILITATOR_URL=https://x402.cspr.cloud/facilitator

# Your Casper payment receiver address
PAYMENT_RECEIVER_ADDRESS=
